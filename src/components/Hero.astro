---
---
<section id="hero" class="relative min-h-screen flex flex-col justify-center overflow-hidden pt-20">
  <canvas id="lightning-canvas" class="absolute inset-0 w-full h-full pointer-events-none"></canvas>
  <div class="absolute inset-0 grid-bg pointer-events-none"></div>

  <div class="relative z-10 container mx-auto px-4 md:px-8 py-16">
    <div class="flex items-center gap-3 mb-6">
      <div class="badge-pulse w-3 h-3 rounded-full" style="background-color: #4ade80;"></div>
      <span class="font-mono text-sm uppercase tracking-widest font-semibold" style="color: #4ade80;">
        Có mặt trong 30 phút
      </span>
      <span class="font-mono text-xs" style="color: #6b7280;">— Phục vụ 24/7</span>
    </div>

    <h1 class="hero-headline mb-4">
      SỬA CHỮA<br>
      <span class="text-orange">ĐIỆN - NƯỚC</span><br>
      <span class="text-gold">ĐIỀU HÒA</span>
    </h1>

    <div class="mb-8 max-w-2xl">
      <p class="font-mono text-base md:text-lg leading-relaxed" style="color: #9ca3af;">
        Dịch vụ sửa chữa chuyên nghiệp tại Hà Nội &amp; TP.HCM.
        <span style="color: white;">Thợ lành nghề</span>,
        <span class="text-orange">giá cố định</span>,
        <span class="text-gold">bảo hành 6 tháng</span>.
      </p>
    </div>

    <div class="flex flex-wrap gap-4 mb-16">
      <a href="tel:0909123456" class="cta-primary flex items-center gap-3 font-mono font-bold text-lg px-8 py-4 uppercase tracking-wider">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
          <path d="M6.6 10.8c1.4 2.8 3.8 5.1 6.6 6.6l2.2-2.2c.3-.3.7-.4 1-.2 1.1.4 2.3.6 3.6.6.6 0 1 .4 1 1V20c0 .6-.4 1-1 1-9.4 0-17-7.6-17-17 0-.6.4-1 1-1h3.5c.6 0 1 .4 1 1 0 1.3.2 2.5.6 3.6.1.3 0 .7-.2 1l-2.3 2.2z"/>
        </svg>
        0909-123-456
      </a>
      <a href="#dat-lich" class="cta-secondary flex items-center gap-3 font-mono font-bold text-lg px-8 py-4 uppercase tracking-wider">
        Đặt Lịch Ngay
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </a>
    </div>

    <div class="stats-grid">
      <div class="stat-item">
        <div class="stat-number text-orange">30'</div>
        <div class="stat-label">Có mặt tại nhà</div>
      </div>
      <div class="stat-item">
        <div class="stat-number text-gold">10+</div>
        <div class="stat-label">Năm kinh nghiệm</div>
      </div>
      <div class="stat-item">
        <div class="stat-number" style="color: white;">5K+</div>
        <div class="stat-label">Khách hài lòng</div>
      </div>
      <div class="stat-item">
        <div class="stat-number" style="color: #4ade80;">24/7</div>
        <div class="stat-label">Hỗ trợ liên tục</div>
      </div>
    </div>
  </div>

  <div class="scroll-indicator">
    <span class="font-mono text-xs uppercase tracking-widest" style="color: #6b7280;">Scroll</span>
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#6b7280" stroke-width="2">
      <path d="M7 10l5 5 5-5"/>
    </svg>
  </div>
</section>

<style>
  #hero {
    background: linear-gradient(135deg, #0a0a0f 0%, #0f0f1a 50%, #0a0a0f 100%);
  }

  .grid-bg {
    background-image:
      linear-gradient(rgba(255, 107, 26, 0.07) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 107, 26, 0.07) 1px, transparent 1px);
    background-size: 60px 60px;
    opacity: 0.15;
  }

  .hero-headline {
    font-family: var(--font-heading);
    font-size: clamp(3rem, 8vw, 7rem);
    line-height: 0.95;
    letter-spacing: -0.01em;
    color: white;
    text-transform: uppercase;
    text-shadow: 0 0 80px rgba(255, 107, 26, 0.15);
  }

  .text-orange { color: #FF6B1A; }
  .text-gold { color: #FFD700; }

  .badge-pulse {
    animation: pulse-badge 2s ease-in-out infinite;
  }

  @keyframes pulse-badge {
    0% { box-shadow: 0 0 0 0 rgba(74, 222, 128, 0.7); }
    70% { box-shadow: 0 0 0 8px rgba(74, 222, 128, 0); }
    100% { box-shadow: 0 0 0 0 rgba(74, 222, 128, 0); }
  }

  .cta-primary {
    background: #FF6B1A;
    color: white;
    clip-path: polygon(0 0, 95% 0, 100% 20%, 100% 100%, 5% 100%, 0 80%);
    transition: all 0.2s ease;
    text-decoration: none;
  }

  .cta-primary:hover {
    background: #e55a0e;
    transform: translateY(-2px);
    box-shadow: 0 8px 25px rgba(255, 107, 26, 0.4);
  }

  .cta-secondary {
    border: 2px solid #2a2a3a;
    color: white;
    clip-path: polygon(0 0, 95% 0, 100% 20%, 100% 100%, 5% 100%, 0 80%);
    transition: all 0.2s ease;
    text-decoration: none;
  }

  .cta-secondary:hover {
    border-color: #FF6B1A;
    color: #FF6B1A;
    transform: translateY(-2px);
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
    max-width: 48rem;
  }

  @media (min-width: 768px) {
    .stats-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  .stat-item {
    padding: 1rem;
    border: 1px solid #2a2a3a;
    background: rgba(255, 107, 26, 0.03);
    position: relative;
  }

  .stat-item::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    width: 3px;
    height: 100%;
    background: #FF6B1A;
    opacity: 0.6;
  }

  .stat-number {
    font-family: var(--font-heading);
    font-size: 3rem;
    letter-spacing: 0.05em;
    color: #FF6B1A;
    line-height: 1;
  }

  .stat-label {
    font-family: var(--font-body);
    font-size: 0.7rem;
    color: #6b7280;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-top: 0.25rem;
  }

  .scroll-indicator {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 10;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    animation: bounce-scroll 2s infinite;
  }

  @keyframes bounce-scroll {
    0%, 100% { transform: translateX(-50%) translateY(0); }
    50% { transform: translateX(-50%) translateY(8px); }
  }
</style>

<script>
  const canvasEl = document.getElementById("lightning-canvas") as HTMLCanvasElement | null;
  if (canvasEl) {
    const ctx = canvasEl.getContext("2d");
    if (ctx) {
      function resizeCanvas() {
        if (canvasEl) {
          canvasEl.width = window.innerWidth;
          canvasEl.height = window.innerHeight;
        }
      }
      resizeCanvas();
      window.addEventListener("resize", resizeCanvas);

      const bolts: {
        segments: Array<{x: number, y: number}>,
        opacity: number,
        maxOpacity: number,
        fade: number,
        width: number,
        color: string
      }[] = [];

      function createSegs(x1: number, y1: number, x2: number, y2: number, r: number): Array<{x: number, y: number}> {
        if (r < 3) return [{x: x1, y: y1}, {x: x2, y: y2}];
        const mx = (x1 + x2) / 2 + (Math.random() - 0.5) * r * 2;
        const my = (y1 + y2) / 2 + (Math.random() - 0.5) * r;
        return [...createSegs(x1, y1, mx, my, r / 2), ...createSegs(mx, my, x2, y2, r / 2).slice(1)];
      }

      function newBolt() {
        const sx = Math.random() * (canvasEl ? canvasEl.width : 800);
        const sy = 0;
        const ex = sx + (Math.random() - 0.5) * 200;
        const ey = Math.random() * ((canvasEl ? canvasEl.height : 600) * 0.65);
        return {
          segments: createSegs(sx, sy, ex, ey, 80),
          opacity: 0,
          maxOpacity: 0.12 + Math.random() * 0.18,
          fade: 0.015 + Math.random() * 0.025,
          width: 0.5 + Math.random() * 1.5,
          color: Math.random() > 0.5 ? "#FF6B1A" : "#FFD700"
        };
      }

      let frame = 0;
      function animate() {
        if (!canvasEl) return;
        ctx.clearRect(0, 0, canvasEl.width, canvasEl.height);
        frame++;
        if (frame % 50 === 0 && bolts.length < 4) bolts.push(newBolt());

        for (let i = bolts.length - 1; i >= 0; i--) {
          const b = bolts[i];
          if (b.opacity < b.maxOpacity) b.opacity += 0.06;
          else b.opacity -= b.fade;
          if (b.opacity <= 0) { bolts.splice(i, 1); continue; }

          ctx.save();
          ctx.globalAlpha = b.opacity * 0.25;
          ctx.shadowColor = b.color;
          ctx.shadowBlur = 20;
          ctx.strokeStyle = b.color;
          ctx.lineWidth = b.width * 5;
          ctx.lineJoin = "round";
          ctx.beginPath();
          b.segments.forEach((pt, idx) => { if (idx === 0) ctx.moveTo(pt.x, pt.y); else ctx.lineTo(pt.x, pt.y); });
          ctx.stroke();
          ctx.restore();

          ctx.save();
          ctx.globalAlpha = b.opacity;
          ctx.strokeStyle = b.color;
          ctx.lineWidth = b.width;
          ctx.lineJoin = "round";
          ctx.beginPath();
          b.segments.forEach((pt, idx) => { if (idx === 0) ctx.moveTo(pt.x, pt.y); else ctx.lineTo(pt.x, pt.y); });
          ctx.stroke();
          ctx.restore();
        }
        requestAnimationFrame(animate);
      }
      animate();
    }
  }
</script>
