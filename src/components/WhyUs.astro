---
const reasons = [
  {
    number: "01",
    icon: "🏆",
    title: "10+ Năm Kinh Nghiệm",
    desc: "Đội ngũ thợ tay nghề cao, qua đào tạo bài bản. Từng xử lý hàng nghìn ca sự cố phức tạp với tỉ lệ thành công 99%.",
    highlight: "10 năm",
  },
  {
    number: "02",
    icon: "🛡️",
    title: "Bảo Hành 6 Tháng",
    desc: "Toàn bộ công việc đều được bảo hành chính thức 6 tháng. Nếu có sự cố sau sửa chữa, chúng tôi quay lại sửa miễn phí.",
    highlight: "Miễn phí",
  },
  {
    number: "03",
    icon: "💰",
    title: "Giá Cố Định",
    desc: "Báo giá rõ ràng trước khi làm, không phát sinh chi phí ẩn. Giá niêm yết minh bạch cho mọi dịch vụ.",
    highlight: "No phát sinh",
  },
  {
    number: "04",
    icon: "🕐",
    title: "Phục Vụ 24/7",
    desc: "Sẵn sàng tiếp nhận và xuất phát bất cứ lúc nào, kể cả đêm khuya, cuối tuần và ngày lễ.",
    highlight: "24/7",
  },
];
---

<section id="tai-sao" class="py-20 md:py-28" style="background: #0d0d14;">
  <div class="container mx-auto px-4 md:px-8">
    <!-- Section Header -->
    <div class="mb-16">
      <div class="section-label mb-3">— Tại Sao Chọn Chúng Tôi —</div>
      <h2 class="section-title">TẠI SAO<br><span style="color: #FF6B1A;">ĐIỆN NƯỚC PRO?</span></h2>
    </div>

    <!-- Reasons Grid -->
    <div class="reasons-grid">
      {reasons.map((r, i) => (
        <div class="reason-card">
          <div class="reason-number">{r.number}</div>
          <div class="reason-icon">{r.icon}</div>
          <h3 class="reason-title">{r.title}</h3>
          <p class="reason-desc">{r.desc}</p>
          <div class="reason-highlight">
            <span class="font-mono text-xs uppercase tracking-widest" style="color: #FF6B1A;">Key: </span>
            <span class="font-mono text-sm font-bold" style="color: #FFD700;">{r.highlight}</span>
          </div>
        </div>
      ))}
    </div>

    <!-- Bottom Banner -->
    <div class="bottom-banner">
      <div class="banner-left">
        <p class="font-mono text-sm" style="color: #9ca3af;">Hotline hỗ trợ khẩn cấp 24/7:</p>
        <a href="tel:0909123456" class="font-heading text-4xl md:text-5xl" style="color: #FFD700; font-family: var(--font-heading);">0909-123-456</a>
      </div>
      <div class="banner-right">
        <a href="tel:0909123456" class="banner-cta font-mono font-bold uppercase tracking-wider">
          Gọi Ngay
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
            <path d="M6.6 10.8c1.4 2.8 3.8 5.1 6.6 6.6l2.2-2.2c.3-.3.7-.4 1-.2 1.1.4 2.3.6 3.6.6.6 0 1 .4 1 1V20c0 .6-.4 1-1 1-9.4 0-17-7.6-17-17 0-.6.4-1 1-1h3.5c.6 0 1 .4 1 1 0 1.3.2 2.5.6 3.6.1.3 0 .7-.2 1l-2.3 2.2z"/>
          </svg>
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .section-label {
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: #FF6B1A;
    display: block;
  }

  .section-title {
    font-family: var(--font-heading);
    font-size: clamp(2.5rem, 5vw, 4rem);
    color: white;
    letter-spacing: 0.05em;
    line-height: 1.0;
  }

  .reasons-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1px;
    background: #2a2a3a;
    border: 1px solid #2a2a3a;
    margin-bottom: 2rem;
  }

  @media (min-width: 768px) {
    .reasons-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .reasons-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  .reason-card {
    background: #111118;
    padding: 2rem 1.5rem;
    position: relative;
    overflow: hidden;
    transition: background 0.3s ease;
  }

  .reason-card:hover {
    background: #14141f;
  }

  .reason-card:hover .reason-number {
    opacity: 0.6;
  }

  .reason-number {
    font-family: var(--font-heading);
    font-size: 5rem;
    color: #FF6B1A;
    opacity: 0.08;
    position: absolute;
    top: -0.5rem;
    right: 1rem;
    line-height: 1;
    transition: opacity 0.3s ease;
  }

  .reason-icon {
    font-size: 2rem;
    margin-bottom: 1rem;
  }

  .reason-title {
    font-family: var(--font-heading);
    font-size: 1.5rem;
    color: white;
    letter-spacing: 0.05em;
    line-height: 1.1;
    margin-bottom: 0.75rem;
  }

  .reason-desc {
    font-family: var(--font-body);
    font-size: 0.8rem;
    color: #6b7280;
    line-height: 1.6;
    margin-bottom: 1rem;
  }

  .reason-highlight {
    padding-top: 0.75rem;
    border-top: 1px solid #2a2a3a;
  }

  .bottom-banner {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    align-items: flex-start;
    padding: 2rem;
    border: 1px solid #2a2a3a;
    background: linear-gradient(90deg, #0f0f1a 0%, #111118 100%);
    position: relative;
    overflow: hidden;
  }

  @media (min-width: 768px) {
    .bottom-banner {
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
    }
  }

  .bottom-banner::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    width: 4px;
    height: 100%;
    background: linear-gradient(to bottom, #FF6B1A, #FFD700);
  }

  .banner-cta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    background: #FF6B1A;
    color: white;
    padding: 1rem 2rem;
    text-decoration: none;
    clip-path: polygon(0 0, 92% 0, 100% 20%, 100% 100%, 8% 100%, 0 80%);
    transition: all 0.2s ease;
    font-size: 1rem;
  }

  .banner-cta:hover {
    background: #e55a0e;
    transform: translateY(-2px);
    box-shadow: 0 8px 25px rgba(255, 107, 26, 0.4);
  }
</style>
