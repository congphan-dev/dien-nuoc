---
---
<footer style="background: #06060a; border-top: 1px solid #2a2a3a;">
  <div class="container mx-auto px-4 md:px-8">
    <!-- Top Section -->
    <div class="footer-top">
      <!-- Brand -->
      <div class="footer-brand">
        <div class="brand-logo">
          <div class="logo-icon">DP</div>
          <div>
            <div class="brand-name">ĐIỆN NƯỚC PRO</div>
            <div class="brand-tagline">Professional Services</div>
          </div>
        </div>
        <p class="brand-desc">
          Dịch vụ sửa chữa điện, nước, điều hòa chuyên nghiệp tại Hà Nội và TP.HCM.
          10 năm kinh nghiệm, bảo hành 6 tháng, có mặt trong 30 phút.
        </p>
        <div class="social-links">
          <a href="#" class="social-link" aria-label="Facebook">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
              <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>
            </svg>
          </a>
          <a href="#" class="social-link" aria-label="Zalo">
            <span class="font-mono text-xs font-bold">Zalo</span>
          </a>
          <a href="#" class="social-link" aria-label="YouTube">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
              <path d="M22.54 6.42a2.78 2.78 0 0 0-1.95-1.96C18.88 4 12 4 12 4s-6.88 0-8.59.46a2.78 2.78 0 0 0-1.95 1.96A29 29 0 0 0 1 12a29 29 0 0 0 .46 5.58A2.78 2.78 0 0 0 3.41 19.6C5.12 20 12 20 12 20s6.88 0 8.59-.46a2.78 2.78 0 0 0 1.95-1.95A29 29 0 0 0 23 12a29 29 0 0 0-.46-5.58z"/>
              <polygon points="9.75 15.02 15.5 12 9.75 8.98 9.75 15.02" fill="#06060a"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Services -->
      <div class="footer-col">
        <h4 class="footer-col-title">Dịch Vụ</h4>
        <ul class="footer-links">
          <li><a href="#dich-vu" class="footer-link">Sửa chữa điện</a></li>
          <li><a href="#dich-vu" class="footer-link">Sửa chữa nước</a></li>
          <li><a href="#dich-vu" class="footer-link">Vệ sinh điều hòa</a></li>
          <li><a href="#dich-vu" class="footer-link">Nạp gas điều hòa</a></li>
          <li><a href="#dich-vu" class="footer-link">Thông cống nghẹt</a></li>
          <li><a href="#dich-vu" class="footer-link">Lắp đặt thiết bị</a></li>
        </ul>
      </div>

      <!-- Contact Info -->
      <div class="footer-col">
        <h4 class="footer-col-title">Liên Hệ</h4>
        <ul class="contact-list">
          <li class="contact-item">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" style="color: #FF6B1A; flex-shrink: 0;">
              <path d="M6.6 10.8c1.4 2.8 3.8 5.1 6.6 6.6l2.2-2.2c.3-.3.7-.4 1-.2 1.1.4 2.3.6 3.6.6.6 0 1 .4 1 1V20c0 .6-.4 1-1 1-9.4 0-17-7.6-17-17 0-.6.4-1 1-1h3.5c.6 0 1 .4 1 1 0 1.3.2 2.5.6 3.6.1.3 0 .7-.2 1l-2.3 2.2z"/>
            </svg>
            <div>
              <div class="font-mono text-xs" style="color: #6b7280;">Hotline 24/7</div>
              <a href="tel:0909123456" class="font-mono font-bold" style="color: #FFD700;">0909-123-456</a>
            </div>
          </li>
          <li class="contact-item">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" style="color: #FF6B1A; flex-shrink: 0;">
              <path d="M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/>
            </svg>
            <a href="mailto:info@diennuocpro.vn" class="font-mono text-sm" style="color: #9ca3af;">info@diennuocpro.vn</a>
          </li>
          <li class="contact-item">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" style="color: #FF6B1A; flex-shrink: 0;">
              <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/>
            </svg>
            <div class="font-mono text-xs" style="color: #9ca3af;">
              <div>123 Đường Giải Phóng, Hoàng Mai, Hà Nội</div>
              <div style="margin-top: 0.25rem;">456 Nguyễn Văn Linh, Quận 7, TP.HCM</div>
            </div>
          </li>
        </ul>
      </div>

      <!-- Working Hours -->
      <div class="footer-col">
        <h4 class="footer-col-title">Giờ Làm Việc</h4>
        <ul class="hours-list">
          <li class="hours-item">
            <span class="font-mono text-xs" style="color: #6b7280;">Thứ 2 - Thứ 6</span>
            <span class="font-mono text-sm font-bold" style="color: white;">7:00 - 21:00</span>
          </li>
          <li class="hours-item">
            <span class="font-mono text-xs" style="color: #6b7280;">Thứ 7 - Chủ nhật</span>
            <span class="font-mono text-sm font-bold" style="color: white;">8:00 - 20:00</span>
          </li>
          <li class="hours-item" style="background: rgba(255, 107, 26, 0.08); padding: 0.75rem; border: 1px solid rgba(255, 107, 26, 0.2);">
            <span class="font-mono text-xs" style="color: #FF6B1A; font-weight: 600;">Sự cố khẩn cấp</span>
            <span class="font-mono text-sm font-bold" style="color: #FF6B1A;">24/7</span>
          </li>
        </ul>
      </div>
    </div>

    <!-- Bottom Bar -->
    <div class="footer-bottom">
      <p class="font-mono text-xs" style="color: #4b5563;">
        &copy; 2025 Điện Nước Pro. Bảo lưu mọi quyền.
      </p>
      <div class="footer-bottom-links">
        <a href="#" class="font-mono text-xs" style="color: #4b5563;">Chính sách bảo mật</a>
        <span style="color: #2a2a3a;">|</span>
        <a href="#" class="font-mono text-xs" style="color: #4b5563;">Điều khoản dịch vụ</a>
      </div>
    </div>
  </div>
</footer>

<style>
  .footer-top {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    padding: 4rem 0 3rem;
  }

  @media (min-width: 768px) {
    .footer-top {
      grid-template-columns: 1.5fr 1fr 1fr 1fr;
    }
  }

  .footer-brand {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .brand-logo {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .logo-icon {
    width: 2.75rem;
    height: 2.75rem;
    background: #FF6B1A;
    color: #0a0a0f;
    font-family: var(--font-heading);
    font-size: 0.9rem;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: bold;
    clip-path: polygon(0 0, 90% 0, 100% 10%, 100% 100%, 10% 100%, 0 90%);
  }

  .brand-name {
    font-family: var(--font-heading);
    font-size: 1.25rem;
    color: white;
    letter-spacing: 0.1em;
  }

  .brand-tagline {
    font-family: var(--font-body);
    font-size: 0.65rem;
    color: #FF6B1A;
    text-transform: uppercase;
    letter-spacing: 0.2em;
  }

  .brand-desc {
    font-family: var(--font-body);
    font-size: 0.8rem;
    color: #6b7280;
    line-height: 1.6;
  }

  .social-links {
    display: flex;
    gap: 0.75rem;
    margin-top: 0.5rem;
  }

  .social-link {
    width: 2.25rem;
    height: 2.25rem;
    border: 1px solid #2a2a3a;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #6b7280;
    text-decoration: none;
    transition: all 0.2s ease;
  }

  .social-link:hover {
    border-color: #FF6B1A;
    color: #FF6B1A;
  }

  .footer-col-title {
    font-family: var(--font-heading);
    font-size: 1.1rem;
    color: white;
    letter-spacing: 0.1em;
    margin-bottom: 1.25rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid #2a2a3a;
    position: relative;
  }

  .footer-col-title::after {
    content: "";
    position: absolute;
    bottom: -1px;
    left: 0;
    width: 30px;
    height: 1px;
    background: #FF6B1A;
  }

  .footer-links {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .footer-link {
    font-family: var(--font-body);
    font-size: 0.8rem;
    color: #6b7280;
    text-decoration: none;
    transition: color 0.2s ease;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .footer-link::before {
    content: "▶";
    font-size: 0.5rem;
    color: #FF6B1A;
    opacity: 0.5;
  }

  .footer-link:hover {
    color: #FF6B1A;
  }

  .contact-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .contact-item {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
  }

  .hours-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .hours-item {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .footer-bottom {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    align-items: center;
    padding: 1.5rem 0;
    border-top: 1px solid #2a2a3a;
    text-align: center;
  }

  @media (min-width: 640px) {
    .footer-bottom {
      flex-direction: row;
      justify-content: space-between;
      text-align: left;
    }
  }

  .footer-bottom-links {
    display: flex;
    gap: 1rem;
    align-items: center;
  }
</style>
