---
---
<header id="site-header" class="fixed top-0 left-0 right-0 z-50 transition-all duration-300">
  <div class="header-inner flex items-center justify-between px-4 md:px-8 py-4">
    <!-- Logo -->
    <a href="/" class="flex items-center gap-3 group">
      <div class="logo-icon w-10 h-10 flex items-center justify-center bg-primary text-dark font-bold text-lg" style="font-family: var(--font-heading); clip-path: polygon(0 0, 90% 0, 100% 10%, 100% 100%, 10% 100%, 0 90%);">
        DP
      </div>
      <div>
        <div class="text-white font-heading text-2xl leading-none tracking-wider" style="font-family: var(--font-heading);">
          ĐIỆN NƯỚC
        </div>
        <div class="text-primary text-xs font-mono tracking-widest font-semibold">
          PRO SERVICES
        </div>
      </div>
    </a>

    <!-- Nav links - desktop -->
    <nav class="hidden lg:flex items-center gap-8">
      <a href="#dich-vu" class="nav-link text-sm font-mono text-gray-400 hover:text-primary transition-colors uppercase tracking-wider">Dịch Vụ</a>
      <a href="#bang-gia" class="nav-link text-sm font-mono text-gray-400 hover:text-primary transition-colors uppercase tracking-wider">Bảng Giá</a>
      <a href="#tai-sao" class="nav-link text-sm font-mono text-gray-400 hover:text-primary transition-colors uppercase tracking-wider">Tại Sao</a>
      <a href="#testimonials" class="nav-link text-sm font-mono text-gray-400 hover:text-primary transition-colors uppercase tracking-wider">Đánh Giá</a>
    </nav>

    <!-- Hotline + CTA -->
    <div class="flex items-center gap-3 md:gap-4">
      <div class="hidden md:flex flex-col items-end">
        <div class="text-xs font-mono text-gray-500 uppercase tracking-wider">Hotline 24/7</div>
        <a href="tel:0909123456" class="text-accent font-mono font-bold text-lg hover:text-primary transition-colors">
          0909-123-456
        </a>
      </div>
      <a href="tel:0909123456" class="cta-btn flex items-center gap-2 bg-primary hover:bg-primary-dark text-white font-mono font-bold text-sm px-5 py-3 transition-all duration-200 uppercase tracking-wider" style="clip-path: polygon(0 0, 95% 0, 100% 15%, 100% 100%, 5% 100%, 0 85%);">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
          <path d="M6.6 10.8c1.4 2.8 3.8 5.1 6.6 6.6l2.2-2.2c.3-.3.7-.4 1-.2 1.1.4 2.3.6 3.6.6.6 0 1 .4 1 1V20c0 .6-.4 1-1 1-9.4 0-17-7.6-17-17 0-.6.4-1 1-1h3.5c.6 0 1 .4 1 1 0 1.3.2 2.5.6 3.6.1.3 0 .7-.2 1l-2.3 2.2z"/>
        </svg>
        Gọi Ngay
      </a>
    </div>
  </div>
</header>

<style>
  #site-header {
    background: rgba(10, 10, 15, 0.85);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid rgba(255, 107, 26, 0.2);
  }

  #site-header.scrolled {
    background: rgba(10, 10, 15, 0.98);
    border-bottom-color: rgba(255, 107, 26, 0.4);
  }

  .logo-icon {
    background: var(--color-primary);
    color: #0a0a0f;
  }

  .nav-link {
    position: relative;
  }

  .nav-link::after {
    content: '';
    position: absolute;
    bottom: -2px;
    left: 0;
    width: 0;
    height: 1px;
    background: var(--color-primary);
    transition: width 0.3s ease;
  }

  .nav-link:hover::after {
    width: 100%;
  }

  .cta-btn {
    position: relative;
    overflow: hidden;
  }

  .cta-btn::before {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background: linear-gradient(90deg, transparent, rgba(255,255,255,0.1), transparent);
    transition: left 0.4s ease;
  }

  .cta-btn:hover::before {
    left: 100%;
  }

  .bg-primary { background-color: #FF6B1A; }
  .bg-primary-dark { background-color: #e55a0e; }
  .hover\:bg-primary-dark:hover { background-color: #e55a0e; }
  .text-primary { color: #FF6B1A; }
  .hover\:text-primary:hover { color: #FF6B1A; }
  .text-accent { color: #FFD700; }
  .text-dark { color: #0a0a0f; }
</style>

<script>
  const header = document.getElementById('site-header');
  
  window.addEventListener('scroll', () => {
    if (window.scrollY > 50) {
      header?.classList.add('scrolled');
    } else {
      header?.classList.remove('scrolled');
    }
  });
</script>
