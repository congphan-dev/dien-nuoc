<div class="ticker-wrapper overflow-hidden" style="background: #FF6B1A; border-top: 1px solid rgba(255,255,255,0.1); border-bottom: 1px solid rgba(255,255,255,0.1);">
  <div class="ticker-inner flex items-center py-3">
    <div class="ticker-track flex items-center gap-0 whitespace-nowrap">
      {Array.from({length: 3}).map(() => (
        <span class="ticker-content flex items-center gap-8 pr-8">
          <span class="font-mono font-bold text-sm uppercase tracking-widest text-white">
            ★ Sửa điện tại nhà
          </span>
          <span class="font-mono text-sm uppercase tracking-widest" style="color: rgba(255,255,255,0.7);">•</span>
