          </span>
          <span class="font-mono text-sm uppercase tracking-widest" style="color: rgba(255,255,255,0.7);">•</span>
          <span class="font-mono font-bold text-sm uppercase tracking-widest text-white">
            ★ Bảo hành 6 tháng
          </span>
          <span class="font-mono text-sm uppercase tracking-widest" style="color: rgba(255,255,255,0.7);">•</span>
          <span class="font-mono font-bold text-sm uppercase tracking-widest text-white">
            ★ Có mặt 30 phút
          </span>
          <span class="font-mono text-sm uppercase tracking-widest" style="color: rgba(255,255,255,0.7);">•</span>
        </span>
      ))}
    </div>
  </div>
</div>

<style>
  .ticker-track {
    animation: ticker-scroll 40s linear infinite;
    display: inline-flex;
  }

  .ticker-wrapper:hover .ticker-track {
    animation-play-state: paused;
  }

  @keyframes ticker-scroll {
    0% { transform: translateX(0); }
    100% { transform: translateX(-33.333%); }
  }
</style>
