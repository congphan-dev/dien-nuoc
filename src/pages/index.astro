---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import Ticker from '../components/Ticker.astro';
import Services from '../components/Services.astro';
import WhyUs from '../components/WhyUs.astro';
import Pricing from '../components/Pricing.astro';
import Testimonials from '../components/Testimonials.astro';
import BookingForm from '../components/BookingForm.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="ĐIỆN NƯỚC PRO - Sửa Chữa Điện, Nước, Điều Hòa Tại Nhà"
  description="Dịch vụ sửa chữa điện, nước, điều hòa. Có mặt trong 30 phút. Hotline: 0909-123-456"
>
  <Header />
  <main>
    <Hero />
    <Ticker />
    <Services />
    <WhyUs />
    <Pricing />
    <Testimonials />
    <BookingForm />
  </main>
  <Footer />
</Layout>
